{
  "name": "@agegate/sdk",
  "version": "1.0.0",
  "description": "Privacy-first age verification middleware using World ID ZKPs",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./middleware": {
      "import": "./dist/middleware.js",
      "require": "./dist/middleware.js",
      "types": "./dist/middleware.d.ts"
    }
  },
  "files": [
    "dist",
    "public/sdk.js",
    "public/verify.html"
  ],
  "scripts": {
    "build:frontend": "esbuild src/frontend.jsx --bundle --outfile=public/bundle.js --loader:.jsx=jsx --define:process.env.NODE_ENV='\"production\"' --minify",
    "start": "npm run build:frontend && tsx src/index.ts",
    "dev": "tsx watch --env-file=.env src/index.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@worldcoin/agentkit": "^0.1.5",
    "@worldcoin/idkit": "^1.5.0",
    "@x402/core": "^2.8.0",
    "@x402/evm": "^2.8.0",
    "@x402/hono": "^2.8.0",
    "esbuild": "^0.27.4",
    "hono": "^4.12.9",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
